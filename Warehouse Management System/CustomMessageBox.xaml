<UserControl x:Class="Warehouse_Management_System.CustomMessageBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Warehouse_Management_System"
             mc:Ignorable="d" d:DesignHeight="200" d:DesignWidth="400">

    <Border x:Name="MainBorder" Background="{DynamicResource BackgroundBrush}" Padding="25">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="MessageText" Grid.Row="0" Text="Текст сообщения" FontSize="16" 
                       Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,20"/>

            <Button Content="OK" Grid.Row="1" Width="90" Height="38" 
                    HorizontalAlignment="Center" Click="OkButton_Click"/>
        </Grid>
    </Border>
</UserControl>
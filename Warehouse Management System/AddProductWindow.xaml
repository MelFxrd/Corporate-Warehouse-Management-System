<UserControl x:Class="Warehouse_Management_System.AddProductWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Warehouse_Management_System"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="400">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <StackPanel Margin="20">

            <TextBlock Text="Название:" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource ForegroundBrush}"/>
            <TextBox x:Name="NameTextBox" Height="25" Margin="0,0,0,10" FontSize="14" BorderThickness="0.5" 
                     Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}" BorderBrush="{DynamicResource ForegroundBrush}"/>

            <TextBlock Text="Количество:" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource ForegroundBrush}"/>
            <TextBox x:Name="QuantityTextBox" Height="25" Margin="0,0,0,10" FontSize="14" BorderThickness="0.5"
                     Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}" BorderBrush="{DynamicResource ForegroundBrush}"/>

            <TextBlock Text="Цена:" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource ForegroundBrush}"/>
            <TextBox x:Name="PriceTextBox" Height="25" Margin="0,0,0,10" FontSize="14" BorderThickness="0.5"
                     Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}" BorderBrush="{DynamicResource ForegroundBrush}"/>

            <TextBlock Text="Категория:" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource ForegroundBrush}"/>
            <ComboBox x:Name="CategoryComboBox" Height="32" Margin="0,0,0,20" FontSize="14" BorderThickness="0.5" 
                      DisplayMemberPath="Name" BorderBrush="{DynamicResource ForegroundBrush}"/>

            <Button Content="Добавить" Width="100" Height="35" HorizontalAlignment="Center" Click="Save_Click"/>

        </StackPanel>
    </Grid>
</UserControl>
<Window x:Class="Warehouse_Management_System.CategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Warehouse_Management_System"
        mc:Ignorable="d" Title="Категории" Height="450" MinWidth="400"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox x:Name="CategoryNameTextBox" Width="270" Height="30" Margin="0,0,10,0" 
                     VerticalContentAlignment="Center" BorderThickness="1"
                     Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}" 
                     BorderBrush="{DynamicResource ForegroundBrush}"/>
            <Button Content="Добавить" Click="AddCategory_Click" Width="100" Height="30"/>
        </StackPanel>

        <ListBox x:Name="CategoriesListBox" Grid.Row="1" Margin="0,0,0,15" DisplayMemberPath="Name" 
                 BorderThickness="1" Background="{DynamicResource BackgroundBrush}" 
                 Foreground="{DynamicResource ForegroundBrush}" BorderBrush="{DynamicResource ForegroundBrush}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Удалить" Click="DeleteCategory_Click" Width="90" Height="32" Margin="0,0,8,0" 
                    Background="Red" Foreground="White" BorderThickness="0"/>
            <Button Content="Изменить" Click="EditCategory_Click" Width="90" Height="32" Margin="0,0,8,0"/>
            <Button Content="Закрыть" Click="Close_Click" Width="90" Height="32"/>
        </StackPanel>
    </Grid>
</Window>